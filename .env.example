# -----------------------------
# App
# -----------------------------
APP_NAME="Claude Agent Queue API"
LOG_LEVEL="INFO"
QUEUES_CONFIG_PATH="config/queues.yaml"

# -----------------------------
# Database (SQLite or MySQL)
# -----------------------------
# SQLite example:
DATABASE_URL="sqlite:///./cc_fastapi.db"
# MySQL example:
# DATABASE_URL="mysql+pymysql://user:password@127.0.0.1:3306/cc_fastapi"

# -----------------------------
# Claude / Agent SDK
# -----------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://aihubmix.com"
API_TIMEOUT_MS="3000000"
ANTHROPIC_DEFAULT_OPUS_MODEL="claude-sonnet-4-5"
ANTHROPIC_DEFAULT_SONNET_MODEL="claude-sonnet-4-5"
ANTHROPIC_DEFAULT_HAIKU_MODEL="claude-haiku-4-5"
ANTHROPIC_MODEL="claude-sonnet-4-5"

# ClaudeAgentOptions mapping
CLAUDE_PERMISSION_MODE="bypassPermissions"
CLAUDE_MAX_TURNS="16"
CLAUDE_CWD="."
# JSON array string preferred, e.g. '["Read","Edit","Bash"]'
CLAUDE_ALLOWED_TOOLS='["Read", "Edit", "Write", "Grep", "Glob"]'
CLAUDE_DISALLOWED_TOOLS="[]"

# -----------------------------
# Worker / Queue policy
# -----------------------------
WORKER_CONCURRENCY="1"
POLL_INTERVAL_MS="1000"
QUEUE_TTL_HOURS="24"
RUNNING_TTL_HOURS="4"
MAX_ATTEMPTS="3"

# -----------------------------
# API auth (optional)
# -----------------------------
# If empty, token auth is disabled.
API_TOKEN=""
